# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Firebase web app API key
NEXT_PUBLIC_FIREBASE_API_KEY=changeme
# Firebase auth domain
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=changeme
# Firebase project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=changeme
# Firebase storage bucket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=changeme
# Firebase messaging sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=changeme
# Firebase app ID
NEXT_PUBLIC_FIREBASE_APP_ID=changeme

# Firebase Admin SDK project ID (server-side only)
FIREBASE_ADMIN_PROJECT_ID=changeme
# Firebase Admin SDK client email (server-side only)
FIREBASE_ADMIN_CLIENT_EMAIL=changeme
# Firebase Admin SDK private key (server-side only)
FIREBASE_ADMIN_PRIVATE_KEY=changeme

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=changeme
# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme
# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=changeme

# Resend transactional email API key
RESEND_API_KEY=changeme

# Google Maps Embed API key (restrict to indianhomes.nl domain)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=changeme

# hCaptcha secret key for server-side verification
HCAPTCHA_SECRET_KEY=changeme
# hCaptcha site key for frontend widget
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=changeme

# Sentry error monitoring DSN
SENTRY_DSN=changeme

# Plausible analytics domain (indianhomes.nl)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=indianhomes.nl
